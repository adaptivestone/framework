{
  "name": "@adaptivestone/framework",
  "version": "5.0.1",
  "description": "Adaptive stone node js framework",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    "./package.json": "./package.json",
    "./server.js": "./dist/server.js",
    "./Cli.js": "./dist/Cli.js",
    "./types.js": "./dist/types.js",
    "./folderConfig.js": "./dist/folderConfig.js",
    "./config/*": "./dist/config/*",
    "./modules/*": "./dist/modules/*",
    "./models/*": "./dist/models/*",
    "./helpers/*": "./dist/helpers/*",
    "./services/*": "./dist/services/*",
    "./controllers/*": "./dist/controllers/*",
    "./tests/*": "./dist/tests/*",
    "./migrations/*": "./dist/migrations/*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adaptivestone/framework.git"
  },
  "homepage": "https://framework.adaptivestone.com/",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "postbuild": "cp -R ./src/migrations ./dist/migrations && cp -R ./src/locales ./dist/locales && cp -R ./src/services/messaging ./dist/services/messaging",
    "check:types": "npm run gen && tsc --noEmit",
    "check:types:raw": "tsc --noEmit",
    "check:types:fast": "npm run gen && tsgo --noEmit",
    "dev": "node --watch ./src/index.ts",
    "prod": "node --watch ./src/cluster.ts",
    "test": "vitest run",
    "t": "vitest --coverage=false --reporter=default",
    "test:node": "node --test --test-global-setup=./src/tests/globalSetupNodeTest.ts 'src/tests/**/*.node-test.ts'",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "prepublishOnly": "npm run gen && npm run build",
    "smoke": "./scripts/packaging-smoke-test.sh",
    "cli": "node cliCommand.ts",
    "gen": "node cliCommand.ts generatetypes",
    "openapi": "node cliCommand.ts openapi",
    "dev:bench:realistic": "node ./benchmark/fixtures/realistic.ts",
    "benchmark": "h2load -n 10000 -c 50 -p 'http/1.1' http://localhost:3300/",
    "benchmark2": "h2load -n 10000 -c 50  https://localhost:3300/",
    "benchmark:plaintext": "h2load -n 10000 -c 50 -p 'http/1.1' http://localhost:3300/bench/plaintext",
    "benchmark:realistic": "h2load -n 10000 -c 50 -p 'http/1.1' 'http://localhost:3300/bench/echo?name=Alice'",
    "redis:docker": "docker run --rm  -p 6379:6379 redis"
  },
  "author": "Andrei Lahunou",
  "license": "MIT",
  "dependencies": {
    "@redis/client": "^6.0.0",
    "deepmerge": "^4.2.2",
    "express": "^5.0.1",
    "formidable": "^3.5.1",
    "i18next": "^26.0.1",
    "i18next-fs-backend": "^2.0.0",
    "mongoose": "^9.0.0",
    "oxc-parser": "^0.137.0",
    "rate-limiter-flexible": "^11.0.0",
    "winston": "^3.3.3",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@sentry/core": "^10.34.0",
    "@sentry/node": "^10.34.0",
    "@types/express": "^5.0.1",
    "@types/formidable": "^3.4.5",
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260604.1",
    "@vitest/coverage-v8": "^4.0.0",
    "lefthook": "^2.0.0",
    "mongodb-memory-server": "^11.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0",
    "yup": "^1.7.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@adaptivestone/framework-module-email": "^1.0.0 || ^2.0.0",
    "@sentry/core": "^10.34.0",
    "@sentry/node": "^10.34.0",
    "mongodb-memory-server": "^11.0.0",
    "vitest": "^4.0.0",
    "yup": "^1.7.0",
    "zod": "^3.24.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@adaptivestone/framework-module-email": {
      "optional": true
    },
    "@sentry/core": {
      "optional": true
    },
    "@sentry/node": {
      "optional": true
    },
    "mongodb-memory-server": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
